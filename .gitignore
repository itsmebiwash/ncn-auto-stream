# Python
__pycache__/
*.py[cod]
*$py.class

# Output generated media — never commit these to git
output/
logs/

# Runtime logs and temp files — never commit
*.log
debug.log
pipeline_debug.log
test_run.log

# Local SQLite fallback database (runtime only)
*.db
local_fallback.db

# Dashboard stats (runtime state)
dashboard_stats.txt

# Keep the folder structure but ignore contents
!output/.gitkeep
!logs/.gitkeep

# Assets (keep logo, templates)
!assets/
!assets/**

# Secrets & local env
.env
run.bat
ncn_autostart.bat

# OS
.DS_Store
Thumbs.db