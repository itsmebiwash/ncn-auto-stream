# Python
__pycache__/
*.py[cod]
*$py.class

# Output generated media — never commit these to git
output/
logs/
debug.log

# Keep the folder structure but ignore contents
!output/.gitkeep
!logs/.gitkeep

# Assets (keep logo, templates)
!assets/
!assets/**

# Secrets & local env
.env
run.bat
ncn_autostart.bat

# OS
.DS_Store
Thumbs.db